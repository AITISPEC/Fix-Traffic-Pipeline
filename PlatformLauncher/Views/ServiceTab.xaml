<UserControl x:Class="PlatformLauncher.Views.ServiceTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Grid Margin="10">
		<StackPanel>
			<Button x:Name="StartWarpButton" Content="Запустить WARP" Width="150" Height="30" Click="StartWarpButton_Click"/>
			<Button x:Name="StopWarpButton" Content="Отключить WARP" Width="150" Height="30" Margin="0,10,0,0" Click="StopWarpButton_Click"/>
		</StackPanel>
	</Grid>
</UserControl>