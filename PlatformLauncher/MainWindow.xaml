<Window x:Class="PlatformLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PlatformLauncher.Views"
        Title="Platform Launcher" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <TabControl>
            <TabItem Header="Фиксы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="RefreshPresetsButton" Content="Обновить пресеты" Width="120" Margin="0,0,10,0" Click="RefreshPresetsButton_Click"/>
                        <Button x:Name="OpenListsButton" Content="LISTS" Width="80" Margin="0,0,10,0" Click="OpenListsButton_Click"/>
                        <CheckBox x:Name="ShowOnlyInstalledCheckBox" Content="Только установленные" Margin="10,0,0,0" VerticalAlignment="Center" Checked="FilterGames_Changed" Unchecked="FilterGames_Changed"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ListBox x:Name="GamesListBox" SelectionChanged="GamesListBox_SelectionChanged" ContextMenuOpening="GamesListBox_ContextMenuOpening">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <ProgressBar x:Name="InstallProgressBar" 
                                                     Width="16" Height="16" 
                                                     Margin="10,0,0,0"
                                                     IsIndeterminate="True"
                                                     Visibility="Collapsed"
                                                     VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Column="1" Margin="10,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Вывод монитора:" FontWeight="Bold"/>
                            <TextBox x:Name="ConsoleOutputTextBox"
                                     Grid.Row="1"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas"
                                     Background="Black"
                                     Foreground="White"
                                     VerticalScrollBarVisibility="Auto"/>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                                <Button x:Name="StartButton" Content="Запустить фикс" Width="120" Margin="0,0,10,0" IsEnabled="False" Click="StartButton_Click"/>
                                <Button x:Name="MonitorButton" Content="Мониторинг" Width="100" Margin="0,0,10,0" IsEnabled="False" Click="MonitorButton_Click"/>
                                <Button x:Name="StopButton" Content="Остановить" Width="80" IsEnabled="False" Click="StopButton_Click"/>
                                <TextBlock x:Name="StatusTextBlock" Text="Готов" Margin="20,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <StatusBar Grid.Row="2" Margin="0,10,0,0">
                        <StatusBarItem>
                            <TextBlock x:Name="StatusBarText" Text="Загрузка пресетов..."/>
                        </StatusBarItem>
                    </StatusBar>
                </Grid>
            </TabItem>
            <TabItem Header="Сервис">
                <views:ServiceTab x:Name="ServiceTabControl" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>