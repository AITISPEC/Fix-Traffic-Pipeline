<UserControl x:Class="PlatformLauncher.Presentation.Views.SettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <TabControl>
        <TabItem Header="Темы" >
            <Grid Margin="10" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions >
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Светлые темы -->
                <StackPanel Grid.Column="0" Grid.Row="0">
                    <TextBlock Text="Светлые темы" FontWeight="Bold" Margin="0,0,0,5" />
                    <ListBox ItemsSource="{Binding LightThemes}"
                     SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                     Height="250"
                     Background="{DynamicResource SecondaryRegionBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     PreviewMouseLeftButtonDown="ThemesListBox_PreviewMouseLeftButtonDown"
                     IsHitTestVisible="{Binding IsThemeChangeAllowed}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" 
                                       VerticalAlignment="Center" 
                                       Width="130" 
                                       Margin="0,0,10,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <Border Width="22" Height="22" Margin="2,0" 
                                    Background="{Binding Background}" 
                                    BorderBrush="Gray" BorderThickness="1" 
                                    ToolTip="Фон" />
                                    <Border Width="22" Height="22" Margin="2,0" 
                                    Background="{Binding Accent}" 
                                    BorderBrush="Gray" BorderThickness="1" 
                                    ToolTip="Акцент" />
                                    <Border Width="22" Height="22" Margin="2,0" 
                                    Background="{Binding Foreground}" 
                                    BorderBrush="Gray" BorderThickness="1" 
                                    ToolTip="Текст" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <!-- Тёмные темы -->
                <StackPanel Grid.Column="2" Grid.Row="0">
                    <TextBlock Text="Тёмные темы" FontWeight="Bold" Margin="0,0,0,5" />
                    <ListBox ItemsSource="{Binding DarkThemes}"
                     SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                     Height="250"
                     Background="{DynamicResource SecondaryRegionBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     PreviewMouseLeftButtonDown="ThemesListBox_PreviewMouseLeftButtonDown"
                     IsHitTestVisible="{Binding IsThemeChangeAllowed}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" 
                                       VerticalAlignment="Center" 
                                       Width="130" 
                                       Margin="0,0,10,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <Border Width="22" Height="22" Margin="2,0" 
                                    Background="{Binding Background}" 
                                    BorderBrush="Gray" BorderThickness="1" 
                                    ToolTip="Фон" />
                                    <Border Width="22" Height="22" Margin="2,0" 
                                    Background="{Binding Accent}" 
                                    BorderBrush="Gray" BorderThickness="1" 
                                    ToolTip="Акцент" />
                                    <Border Width="22" Height="22" Margin="2,0" 
                                    Background="{Binding Foreground}" 
                                    BorderBrush="Gray" BorderThickness="1" 
                                    ToolTip="Текст" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <!-- Индикатор блокировки смены тем -->
                <StackPanel Grid.Row="1" Grid.ColumnSpan="3"
                             Orientation="Horizontal"
                             HorizontalAlignment="Center"
                             Margin="0,10,0,0"
                             Visibility="{Binding LockVisibility}">
                    <Viewbox Width="20" Height="20" Margin="0,0,8,0">
                        <Path Data="M12 2C9.24 2 7 4.24 7 7v3H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8a2 2 0 0 0-2-2h-1V7c0-2.76-2.24-5-5-5zm0 2c1.65 0 3 1.35 3 3v3H9V7c0-1.65 1.35-3 3-3zm0 10c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2z"
                               Fill="{DynamicResource PrimaryTextBrush}"
                               Stretch="Uniform" />
                    </Viewbox>
                    <TextBlock Text="Смена темы заблокирована во время сессии"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                VerticalAlignment="Center"
                                FontSize="13" />
                </StackPanel>
            </Grid>
        </TabItem>
        <TabItem Header="Монитор">
            <StackPanel Margin="10">
                <TextBlock Text="Настройки мониторинга (в разработке)" />
            </StackPanel>
        </TabItem>
        <TabItem Header="Дебаг">
            <StackPanel Margin="10">
                <CheckBox Content="Запись дебаг логов"
                          IsChecked="{Binding DebugEnabled, Mode=TwoWay}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          Checked="DebugCheckBox_Changed"
                          Unchecked="DebugCheckBox_Changed"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</UserControl>