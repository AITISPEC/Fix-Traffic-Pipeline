<Window x:Class="PlatformLauncher.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syswin="clr-namespace:System.Windows;assembly=PresentationFramework"
        xmlns:views="clr-namespace:PlatformLauncher.Presentation.Views"
        xmlns:term="clr-namespace:EasyWindowsTerminalControl;assembly=EasyWindowsTerminalControl"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:controls="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="Fix Traffic Pipeline" Height="600" Width="919.1"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="{DynamicResource RegionBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}">
    <Window.Resources>
        <controls:BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Шаблон для скроллбара терминала -->
        <ControlTemplate x:Key="TerminalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Background="{TemplateBinding Background}">
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageUpCommand" Background="Transparent" BorderThickness="0"/>
                    </Track.DecreaseRepeatButton>

                    <Track.Thumb>
                        <Thumb Background="{TemplateBinding Foreground}">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="3"
                                    Margin="1"/>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Track.Thumb>

                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageDownCommand" Background="Transparent" BorderThickness="0"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <!-- Implicit styles для всех WPF контролов — ПЕРЕКРЫВАЮТ HandyControl -->
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <!-- Наведение мыши -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource HoverBrush}"/>
                </Trigger>
                <!-- Нажатие -->
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                </Trigger>
                <!-- Неактивная -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ThirdlyTextBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                    <Setter Property="Opacity" Value="0.4"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ListBox с BasedOn -->
        <Style TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TabControl с BasedOn -->
        <Style TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
            <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <Style TargetType="StatusBarItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1,1,1,0"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}"
                                CornerRadius="4,4,0,0">
                            <ContentPresenter ContentSource="Header"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                <Setter Property="Panel.ZIndex" Value="1" />
                            </Trigger>
                            <Trigger SourceName="Border" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator" BasedOn="{StaticResource {x:Type Separator}}">
            <Setter Property="Background" Value="{DynamicResource SeparatorBrush}"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="15*"/>
            <ColumnDefinition Width="584*"/>
            <ColumnDefinition Width="299*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <hc:SimplePanel Grid.Row="0" Margin="0,0,0,10" Grid.ColumnSpan="3"
                        Background="{DynamicResource RegionBrush}">
            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                <Button Content="Обновить список" Width="120" Margin="0,0,10,0"
                        Command="{Binding RefreshPresetsCommand}" FontSize="11"/>
                <CheckBox Content="Только установленные" Margin="10,0,0,0" VerticalAlignment="Center"
                          IsChecked="{Binding ShowOnlyInstalled, Mode=TwoWay}"
                          Command="{Binding FilterCommand}"/>
                <CheckBox Content="Только локальные" Margin="10,0,0,0" VerticalAlignment="Center"
                          IsChecked="{Binding ShowOnlyLocal, Mode=TwoWay}"
                          Command="{Binding FilterCommand}"/>
            </StackPanel>
        </hc:SimplePanel>

        <!-- TabControl -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Grid.ColumnSpan="3">
            <TabItem Header="Фиксы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="103*"/>
                        <RowDefinition Height="134*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ListBox ItemsSource="{Binding Games}"
                             SelectedItem="{Binding SelectedGame}"
                             Grid.RowSpan="2"
                             Background="{DynamicResource SecondaryRegionBrush}"
                             BorderBrush="{DynamicResource BorderBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    <ProgressBar Width="16" Height="16" Margin="10,0,0,0"
                                                 IsIndeterminate="True"
                                                 Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVisibility}}"
                                                 VerticalAlignment="Center"/>
                                    <ProgressBar Width="16" Height="16" Margin="10,0,0,0"
                                                 IsIndeterminate="True"
                                                 Visibility="{Binding IsUninstalling, Converter={StaticResource BoolToVisibility}}"
                                                 VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Установить" Command="{Binding InstallCommand}" CommandParameter="{Binding SelectedGame}"/>
                                <MenuItem Header="Удалить" Command="{Binding UninstallCommand}" CommandParameter="{Binding SelectedGame}"/>
                                <MenuItem Header="Свойства" Command="{Binding PropertiesCommand}" CommandParameter="{Binding SelectedGame}"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>

                    <!-- Правая часть -->
                    <Grid Grid.Column="1" Margin="10,0,0,0" Grid.RowSpan="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <term:EasyTerminalControl x:Name="ConsoleOutputTerminal"
                                                 FontSizeWhenSettingTheme="10"
                                                 Grid.Row="1"
                                                 StartupCommandLine="cmd.exe /c"
                                                 LogConPTYOutput="True"
                                                 Win32InputMode="True"
                                                 InputCapture="TabKey,DirectionKeys"
                                                 Margin="0,0,0,25"
                                                 Grid.RowSpan="2"
                                                 PreviewKeyDown="ConsoleOutputTerminal_PreviewKeyDown"
                                                 Loaded="ConsoleOutputTerminal_Loaded">
                            <term:EasyTerminalControl.ContextMenu>
                                <ContextMenu DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <MenuItem Header="Версия Python" Command="{Binding RunCommandCommand}" CommandParameter="python -V"/>
                                    <MenuItem Header="Версия PIP" Command="{Binding RunCommandCommand}" CommandParameter="pip -V"/>
                                    <MenuItem Header="Обновить PIP" Command="{Binding RunCommandCommand}" CommandParameter="python -m pip install --upgrade pip"/>
                                    <MenuItem Header="Список пакетов" Command="{Binding RunCommandCommand}" CommandParameter="pip list"/>
                                    <MenuItem Header="Обновить пакеты" Command="{Binding RunCommandCommand}" CommandParameter="pip list --outdated --format=freeze | foreach { pip install --upgrade $_.Split('==')[0] }"/>
                                    <Separator/>
                                    <MenuItem Header="Очистить" Command="{Binding ClearConsoleCommand}"/>
                                </ContextMenu>
                            </term:EasyTerminalControl.ContextMenu>
                            <term:EasyTerminalControl.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}"/>
                                <Style TargetType="ContextMenu">
                                    <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                </Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                    <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
                                </Style>
                            </term:EasyTerminalControl.Resources>
                        </term:EasyTerminalControl>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="{Binding StartButtonText}" Width="120" Margin="0,0,10,0"
                                    Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}"/>
                            <Button Content="Мониторинг" Width="100" Margin="0,0,10,0"
                                    Command="{Binding MonitorCommand}" IsEnabled="{Binding CanMonitor}"/>
                            <Button Content="Остановить" Width="80"
                                    Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                            <TextBlock Text="{Binding StatusText}" Margin="20,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Сервис">
                <views:ServiceTab x:Name="ServiceTabControl"/>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2" Margin="0,10,0,0" Grid.ColumnSpan="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusBarText}"/>
            </StatusBarItem>
        </StatusBar>

        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="Fix Traffic Pipeline"
                        DoubleClickCommand="{Binding ShowWindowCommand}"
                        Grid.ColumnSpan="3"
                        Grid.RowSpan="2">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Показать" Command="{Binding ShowWindowCommand}"/>
                    <MenuItem Header="Закрыть" Click="ExitMenuItem_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>