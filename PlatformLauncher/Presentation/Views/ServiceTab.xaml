<UserControl x:Class="PlatformLauncher.Presentation.Views.ServiceTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ControlBackground}"
             Foreground="{DynamicResource MainForeground}">
    <TabControl Background="{DynamicResource ControlBackground}"
                Foreground="{DynamicResource MainForeground}"
                BorderBrush="{DynamicResource BorderBrush}">
        <TabItem Header="WARP">
            <StackPanel Margin="10">
                <Button Content="Запустить WARP" Width="150" Height="30"
                        Command="{Binding StartWarpCommand}"
                        IsEnabled="{Binding CanStartWarp}"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource ControlForeground}"
                        BorderBrush="{DynamicResource BorderBrush}"/>
                <Button Content="Отключить WARP" Width="150" Height="30" Margin="0,10,0,0"
                        Command="{Binding StopWarpCommand}"
                        IsEnabled="{Binding CanStopWarp}"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource ControlForeground}"
                        BorderBrush="{DynamicResource BorderBrush}"/>
                <Button Content="Прописать в листы" 
                        Command="{Binding WriteCloudflareCommand}"
                        Width="150" Height="30" Margin="0,10,0,0"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource ControlForeground}"
                        BorderBrush="{DynamicResource BorderBrush}"/>
                <TextBlock Text="{Binding WarpStatus, StringFormat='Статус: {0}'}" Margin="0,10,0,0"
                           Foreground="{DynamicResource MainForeground}"/>
            </StackPanel>
        </TabItem>
        <TabItem Header="Темы">
            <StackPanel Margin="10">
                <TextBlock Text="Выберите тему оформления:" FontWeight="Bold"
                           Foreground="{DynamicResource MainForeground}"/>
                <ListBox ItemsSource="{Binding Themes}"
                         SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                         DisplayMemberPath="DisplayName"
                         Height="200"
                         Background="{DynamicResource ControlBackground}"
                         Foreground="{DynamicResource MainForeground}"
                         BorderBrush="{DynamicResource BorderBrush}"/>
            </StackPanel>
        </TabItem>
        <TabItem Header="Монитор">
            <StackPanel Margin="10">
                <TextBlock Text="Настройки мониторинга (в разработке)"
                           Foreground="{DynamicResource MainForeground}"/>
            </StackPanel>
        </TabItem>
        <TabItem Header="Помощь">
            <StackPanel Margin="10">
                <Button Content="Починить интернет (сброс DNS)"
                        Command="{Binding FixInternetCommand}"
                        Width="200" Height="30" Margin="0,10"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource ControlForeground}"
                        BorderBrush="{DynamicResource BorderBrush}"/>
                <TextBlock Text="При проблемах с доступом после установки WARP запустите эту функцию. Она очищает зависшие DNS-настройки Cloudflare."
                           TextWrapping="Wrap" Margin="0,10,0,0"
                           Foreground="{DynamicResource MainForeground}"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</UserControl>