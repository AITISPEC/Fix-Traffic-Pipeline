<UserControl x:Class="PlatformLauncher.Presentation.Views.ServiceTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <TabControl SelectionChanged="TabControl_SelectionChanged">
        <TabItem Header="ZDY">
            <StackPanel Margin="10">
                <TextBlock Text="Текущее расположение папки lists:" FontWeight="Bold" Margin="0,0,0,5" Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="{Binding ListsPath}"
                           TextWrapping="Wrap" Margin="0,0,0,15"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <Button Content="Выбрать расположение" Width="200" Height="30" 
                        Command="{Binding SelectListsPathCommand}"
                        HorizontalAlignment="Left"/>
                <Button Content="Открыть папку" Width="200" Height="30" Margin="0,10,0,0" 
                        Command="{Binding OpenListsFolderCommand}"
                        HorizontalAlignment="Left"/>
                <Button Content="service.bat" Width="200" Height="30" Margin="0,10,0,0"
                        Command="{Binding RunServiceBatCommand}"
                        HorizontalAlignment="Left" />
            </StackPanel>
        </TabItem>
        <TabItem Header="WARP">
            <StackPanel Margin="10">
                <TextBlock Text="{Binding WarpStatus, StringFormat='Статус: {0}'}" Margin="0,10,0,0"/>
                <Button Content="Запустить WARP" Width="150" Height="30"
                        Command="{Binding StartWarpCommand}"
                        IsEnabled="{Binding CanStartWarp}"
                        HorizontalAlignment="Left"/>
                <Button Content="Отключить WARP" Width="150" Height="30" Margin="0,10,0,0"
                        Command="{Binding StopWarpCommand}"
                        IsEnabled="{Binding CanStopWarp}"
                        HorizontalAlignment="Left"/>
                <Button Content="Прописать в листы" Width="150" Height="30" Margin="0,10,0,0"
                        Command="{Binding WriteCloudflareCommand}"
                        HorizontalAlignment="Left"/>
            </StackPanel>
        </TabItem>
        <TabItem Header="Помощь">
            <StackPanel Margin="10">
                <Button Content="Починить интернет (сброс DNS)" Width="200" Height="30" Margin="0,10"
                        Command="{Binding FixInternetCommand}"
                        HorizontalAlignment="Left"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</UserControl>