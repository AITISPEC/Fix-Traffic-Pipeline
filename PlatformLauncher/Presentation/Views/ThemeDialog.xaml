<Window x:Class="PlatformLauncher.Views.ThemeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор темы" Height="180" Width="300"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Выберите тему терминала:" FontWeight="Bold" Margin="0,0,0,10"/>
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <RadioButton x:Name="DarkThemeRadio" Content="Тёмная" GroupName="ThemeGroup" IsChecked="True" Margin="0,5"/>
            <RadioButton x:Name="LightThemeRadio" Content="Светлая" GroupName="ThemeGroup" Margin="0,5"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,10,0" Click="OkButton_Click"/>
            <Button Content="Отмена" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>