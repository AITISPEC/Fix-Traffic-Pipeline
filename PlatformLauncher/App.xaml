<Application x:Class="PlatformLauncher.AppHost.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <hc:Theme/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Дефолтные цвета (будут перезаписаны при загрузке темы) -->
            <SolidColorBrush x:Key="RegionBrush" Color="#1A1A2E"/>
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#CDD6F4"/>
            <SolidColorBrush x:Key="SecondaryRegionBrush" Color="#2A2A3E"/>
            <SolidColorBrush x:Key="PrimaryBrush" Color="#89B4FA"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#454560"/>
            <SolidColorBrush x:Key="MainBackground" Color="#1A1A2E"/>
            <SolidColorBrush x:Key="MainForeground" Color="#CDD6F4"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#89B4FA"/>
            <SolidColorBrush x:Key="ControlBackground" Color="#2A2A3E"/>
            <SolidColorBrush x:Key="ControlForeground" Color="#CDD6F4"/>
            <SolidColorBrush x:Key="ScrollBarBackground" Color="#2b2b2b"/>
            <SolidColorBrush x:Key="ScrollBarForeground" Color="#3c3c3c"/>
            <SolidColorBrush x:Key="ThirdlyTextBrush" Color="#CDD6F4"/>

            <!-- Implicit styles для всех WPF контролов --> 
            <Style TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            </Style>

            <Style TargetType="ListBox">
                <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            </Style>

            <Style TargetType="ListBoxItem">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="TabControl">
                <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            </Style>

            <Style TargetType="TabItem">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            </Style>

            <Style TargetType="StatusBar">
                <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            </Style>

            <Style TargetType="StatusBarItem">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            </Style>

            <Style TargetType="ScrollBar">
                <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            </Style>

            <Style TargetType="MenuItem">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            </Style>

            <Style TargetType="ContextMenu">
                <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>