<UserControl x:Class="PlatformLauncher.Presentation.Views.ServiceTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:PlatformLauncher.Presentation.Views"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>
    <Grid>
        <TabControl SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="ZDY">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="10" Grid.Column="0">
                        <TextBlock Text="Текущее расположение папки lists:" FontWeight="Bold" Margin="0,5,0,5" 
                                   Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ListsPath}" TextWrapping="Wrap" Margin="0,5,0,5"
                                   Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" FontSize="10"/>
                        <Button Content="Выбрать расположение" Width="228" Height="30" 
                                Command="{Binding SelectListsPathCommand}" HorizontalAlignment="Left"/>
                        <Button Content="Открыть папку" Width="228" Height="30" Margin="0,10,0,0" 
                                Command="{Binding OpenListsFolderCommand}"
                                IsEnabled="{Binding IsZapretValid}" HorizontalAlignment="Left"/>
                        <Button Content="Запустить Service" Width="228" Height="30" Margin="0,10,0,0"
                                Command="{Binding RunServiceBatCommand}"
                                IsEnabled="{Binding IsZapretValid}" HorizontalAlignment="Left"/>
                        <Button Content="Запустить Zapret" Width="228" Height="30" Margin="0,10,0,0"
                                Command="{Binding RunZapretCommand}"
                                IsEnabled="{Binding CanRunZapret}" HorizontalAlignment="Left"/>
                        <Button Content="Установить Zapret" Width="228" Height="30" Margin="0,10,0,0"
                                Command="{Binding InstallZapretCommand}"
                                IsEnabled="{Binding IsZapretMissing}" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <views:ServiceLogBox x:Name="ZdyLogBox" Grid.Column="1" Margin="0,10,10,10" LogId="ZDY"/>
                </Grid>
            </TabItem>
            <TabItem Header="WARP">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="10" Grid.Column="0">
                        <TextBlock Text="{Binding WarpStatus, StringFormat='Статус: {0}'}" Margin="0,5,0,5" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Button Content="Установить WARP" Width="228" Height="30" Margin="0,10,0,0"
                                Command="{Binding InstallWarpCommand}"
                                IsEnabled="{Binding CanInstallWarp}" HorizontalAlignment="Left"/>
                        <Button Content="Запустить WARP" Width="228" Height="30" Margin="0,10,0,0"
                                Command="{Binding StartWarpCommand}"
                                IsEnabled="{Binding CanStartWarp}" HorizontalAlignment="Left"/>
                        <Button Content="Отключить WARP" Width="228" Height="30" Margin="0,10,0,0"
                                Command="{Binding StopWarpCommand}"
                                IsEnabled="{Binding CanStopWarp}" HorizontalAlignment="Left"/>
                        <Button Content="Прописать в листы" Width="228" Height="30" Margin="0,10,0,0"
                                Command="{Binding WriteCloudflareCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <views:ServiceLogBox x:Name="WarpLogBox" Grid.Column="1" Margin="0,10,10,10" LogId="WARP"/>
                </Grid>
            </TabItem>
            <TabItem Header="Python">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="10" Grid.Column="0">
                        <TextBlock Text="Управление окружением Python" FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Center" Height="20" Margin="0,5,0,5"/>
                        <Button Content="Установить" Width="228" Height="30" 
                                Command="{Binding InstallPythonCommand}"
                                IsEnabled="{Binding CanInstallPython}" HorizontalAlignment="Left" />
                        <Button Content="Создать окружение" Width="228" Height="30" Margin="0,10,0,0"
                                Command="{Binding CreateVenvCommand}"
                                IsEnabled="{Binding CanCreateVenv}" HorizontalAlignment="Left" />
                    </StackPanel>
                    <!-- ИСПРАВЛЕНО: добавлена закрывающая кавычка после Python -->
                    <views:ServiceLogBox x:Name="PythonLogBox" Grid.Column="1" Margin="0,10,10,10" LogId="Python"/>
                </Grid>
            </TabItem>
            <TabItem Header="Помощь">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="10" Grid.Column="0">
                        <Button Content="Починить интернет (сброс DNS)" Width="228" Height="30" Margin="0,10"
                                Command="{Binding FixInternetCommand}" HorizontalAlignment="Left"/>
                        <Button Content="Починить Python" Width="228" Height="30" Margin="0,10,0,0"
                                Command="{Binding FixPythonPathCommand}" HorizontalAlignment="Left" />
                    </StackPanel>
                    <views:ServiceLogBox x:Name="HelpLogBox" Grid.Column="1" Margin="0,10,10,10" LogId="Help"/>
                </Grid>
            </TabItem>
        </TabControl>
        <Border Background="Transparent"
                d:Visibility="Collapsed"
                IsHitTestVisible="{Binding IsSessionActive}"
                Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVisibility}}"/>
    </Grid>
</UserControl>