<Window x:Class="PlatformLauncher.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syswin="clr-namespace:System.Windows;assembly=PresentationFramework"
        xmlns:views="clr-namespace:PlatformLauncher.Presentation.Views"
        xmlns:term="clr-namespace:EasyWindowsTerminalControl;assembly=EasyWindowsTerminalControl"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:controls="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="Fix Traffic Pipeline" Height="600" Width="919.1"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="{DynamicResource RegionBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}">
    <Window.Resources>
        <controls:BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Шаблон для скроллбара терминала -->
        <ControlTemplate x:Key="TerminalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Background="{TemplateBinding Background}">
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageUpCommand" Background="Transparent" BorderThickness="0"/>
                    </Track.DecreaseRepeatButton>

                    <Track.Thumb>
                        <Thumb Background="{TemplateBinding Foreground}">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="3"
                                    Margin="1"/>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Track.Thumb>

                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageDownCommand" Background="Transparent" BorderThickness="0"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style x:Key="ScrollBarArrowButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent">
                            <Path x:Name="Arrow"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RepeatButton}}"
                          Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="3"
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource HoverBrush}" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BorderBrush}" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                <Setter TargetName="Border" Property="Opacity" Value="0.4" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
            <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <Style TargetType="StatusBarItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1,1,1,0"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}"
                                CornerRadius="4,4,0,0">
                            <ContentPresenter ContentSource="Header"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                <Setter Property="Panel.ZIndex" Value="1" />
                            </Trigger>
                            <Trigger SourceName="Border" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource HoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator" BasedOn="{StaticResource {x:Type Separator}}">
            <Setter Property="Background" Value="{DynamicResource SeparatorBrush}"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
    </Window.Resources>

    <Grid PreviewMouseDown="RootGrid_PreviewMouseDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="15*"/>
            <ColumnDefinition Width="584*"/>
            <ColumnDefinition Width="299*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <hc:SimplePanel Grid.Row="0" Margin="0,0,0,10" Grid.ColumnSpan="3"
                        Background="{DynamicResource RegionBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="2,0,0,0" HorizontalAlignment="Left">
                    <Button Content="Обновить список" Width="120" Margin="0,3,15,0"
                            Command="{Binding RefreshPresetsCommand}" FontSize="11"/>
                </StackPanel>

                <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,15,0"/>
            </Grid>
        </hc:SimplePanel>

        <!-- TabControl -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Grid.ColumnSpan="3" SelectionChanged="MainTabControl_SelectionChanged">
            <TabItem Header="Фиксы" Width="83">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Для панели поиска -->
                        <RowDefinition Height="*"/>
                        <!-- Для ListBox и Expander -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Панель поиска и сортировки -->
                    <Border Grid.Row="0" Grid.Column="0" 
                            Background="{DynamicResource RegionBrush}" 
                            Padding="5" Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <!-- Поиск -->
                            <Grid Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="SearchTextBox"
                                         Grid.Column="0"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="16"
                                         Background="{DynamicResource InputBackground}"
                                         Foreground="{DynamicResource InputForeground}"
                                         BorderBrush="{DynamicResource InputBorderBrush}"
                                         FontSize="12"
                                         Padding="5,3,24,3"
                                         GotFocus="SearchTextBox_GotFocus"
                                         LostFocus="SearchTextBox_LostFocus"
                                         TextChanged="SearchTextBox_TextChanged"/>

                                <!-- Полупрозрачный текст-подсказка поверх TextBox -->
                                <TextBlock x:Name="SearchPlaceholder"
                                           Text="Поиск..."
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Opacity="0.5"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           FontSize="12"/>

                                <!-- Крестик для очистки поиска -->
                                <Button x:Name="ClearSearchButton"
                                        Grid.Column="1"
                                        ToolTip="Очистить поиск"
                                        Width="22"
                                        Height="22"
                                        Margin="2,0,0,0"
                                        Padding="4"
                                        Visibility="Collapsed"
                                        Click="ClearSearchButton_Click">
                                    <Viewbox Width="10" Height="10">
                                        <Path Data="M 0,0 L 10,10 M 10,0 L 0,10"
                                              Stroke="{DynamicResource PrimaryTextBrush}"
                                              StrokeThickness="1.5"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              SnapsToDevicePixels="True"
                                              UseLayoutRounding="True" />
                                    </Viewbox>
                                </Button>
                            </Grid>

                            <!-- Сортировка -->
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding SortOptions}"
                                      SelectedItem="{Binding SelectedSortOption}"
                                      DisplayMemberPath="DisplayName"
                                      Background="{DynamicResource InputBackground}"
                                      Foreground="{DynamicResource InputForeground}"
                                      BorderBrush="{DynamicResource InputBorderBrush}"
                                      FontSize="10"
                                      Padding="3,2"/>
                        </Grid>
                    </Border>

                    <!-- Левая колонка: ListBox + Expander с фильтрами -->
                    <Grid Grid.Column="0" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListBox x:Name="GamesListBox"
                                 ItemsSource="{Binding Games}"
                                 SelectedItem="{Binding SelectedGame}"
                                 Grid.Row="0"
                                 Background="{DynamicResource SecondaryRegionBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 PreviewMouseLeftButtonDown="ListBox_PreviewMouseLeftButtonDown"
                                 PreviewMouseRightButtonDown="ListBox_PreviewMouseRightButtonDown">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                <!-- Заменяем Header и Command на новые свойства -->
                                                <MenuItem Header="{Binding DataContext.ContextMenuActionText, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Command="{Binding DataContext.ContextMenuActionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="Удалить" Command="{Binding UninstallCommand}" />
                                                <MenuItem Header="Свойства" Command="{Binding PropertiesCommand}" />
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                        <ProgressBar Width="16" Height="16" Margin="10,0,0,0"
                                                     IsIndeterminate="True"
                                                     Visibility="{Binding DataContext.GlobalInstalling, 
                                                                 RelativeSource={RelativeSource AncestorType=Window},
                                                                 Converter={StaticResource BoolToVisibility}}"
                                                     VerticalAlignment="Center" />
                                        <ProgressBar Width="16" Height="16" Margin="10,0,0,0"
                                                     IsIndeterminate="True"
                                                     Visibility="{Binding DataContext.GlobalUninstalling, 
                                                                 RelativeSource={RelativeSource AncestorType=Window},
                                                                 Converter={StaticResource BoolToVisibility}}"
                                                     VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Раскрывающийся список фильтров -->
                        <Expander x:Name="FiltersExpander"
                                  Grid.Row="1"
                                  Header="{Binding FilterHeader}"
                                  IsExpanded="False"
                                  ExpandDirection="Up"
                                  Background="{DynamicResource SecondaryRegionBrush}"
                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  BorderThickness="0,1,0,0"
                                  Padding="5,3">
                            <Grid Margin="5,5,5,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <CheckBox Content="Установленные"
                                              IsChecked="{Binding FilterInstalled, Mode=TwoWay}"
                                              Foreground="{DynamicResource PrimaryTextBrush}"
                                              Margin="0,0,0,4"/>
                                    <CheckBox Content="Не установленные"
                                              IsChecked="{Binding FilterNotInstalled, Mode=TwoWay}"
                                              Foreground="{DynamicResource PrimaryTextBrush}"
                                              Margin="0,0,0,4"/>
                                    <CheckBox Content="Пользовательские"
                                              IsChecked="{Binding FilterCustom, Mode=TwoWay}"
                                              Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        ToolTip="Сбросить все фильтры"
                                        Command="{Binding ResetFiltersCommand}"
                                        Width="26"
                                        Height="26"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Top"
                                        Padding="6">
                                    <Viewbox Width="12" Height="12">
                                        <Path Data="M 0,0 L 10,10 M 10,0 L 0,10"
                                              Stroke="{DynamicResource PrimaryTextBrush}"
                                              StrokeThickness="1.5"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              SnapsToDevicePixels="True"
                                              UseLayoutRounding="True" />
                                    </Viewbox>
                                </Button>
                            </Grid>
                        </Expander>
                    </Grid>

                    <!-- ПКМ терминал -->
                    <Grid Grid.Column="1" Margin="10,0,0,0" Grid.RowSpan="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <term:EasyTerminalControl x:Name="ConsoleOutputTerminal"
                                                  FontSizeWhenSettingTheme="10"
                                                  Grid.Row="1"
                                                  StartupCommandLine="cmd.exe /c"
                                                  LogConPTYOutput="True"
                                                  Win32InputMode="True"
                                                  InputCapture="TabKey,DirectionKeys"
                                                  Margin="0,0,0,30"
                                                  Grid.RowSpan="2"
                                                  PreviewKeyDown="ConsoleOutputTerminal_PreviewKeyDown"
                                                  Loaded="ConsoleOutputTerminal_Loaded">
                            <term:EasyTerminalControl.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Версия Python" Command="{Binding RunCommandCommand}" CommandParameter="python -V" />
                                        <MenuItem Header="Версия PIP" Command="{Binding RunCommandCommand}" CommandParameter="pip -V" />
                                        <MenuItem Header="Обновить PIP" Command="{Binding RunCommandCommand}" CommandParameter="python -m pip install --upgrade pip" />
                                        <MenuItem Header="Список пакетов" Command="{Binding RunCommandCommand}" CommandParameter="pip list" />
                                        <MenuItem Header="Обновить пакеты" Command="{Binding RunCommandCommand}" CommandParameter="pip list --outdated --format=freeze | foreach { pip install --upgrade $_.Split('==')[0] }" />
                                        <MenuItem Header="Очистить" Command="{Binding ClearConsoleCommand}" />
                                    </ContextMenu>
                                </term:EasyTerminalControl.ContextMenu>
                                <term:EasyTerminalControl.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}"/>
                                    <Style TargetType="ContextMenu">
                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    </Style>
                                    <Style TargetType="MenuItem" BasedOn="{x:Null}">
                                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
                                        <Setter Property="Padding" Value="10,5"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="MenuItem">
                                                    <Border x:Name="Bd" 
                                                Background="{TemplateBinding Background}" 
                                                Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter ContentSource="Header"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsHighlighted" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Foreground" Value="{DynamicResource DisabledForeground}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </term:EasyTerminalControl.Resources>
                            </term:EasyTerminalControl>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="{Binding StartButtonText}" Width="120" Margin="0,0,10,0"
                                    Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}" />
                            <Button Content="Мониторинг" Width="100" Margin="0,0,10,0"
                                    Command="{Binding MonitorCommand}" IsEnabled="{Binding CanMonitor}" />
                            <Button Content="Остановить" Width="80"
                                    Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                            <TextBlock Text="{Binding StatusText}" Margin="20,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Width="83">
                <TabItem.Header>
                    <TextBlock x:Name="ServiceTabHeader" Text="Сервис"/>
                </TabItem.Header>
                <views:ServiceTab x:Name="ServiceTabControl"/>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock x:Name="SettingsTabHeader" Text="Настройки"/>
                </TabItem.Header>
                <views:SettingsTab x:Name="SettingsTabControl"/>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2" Margin="0,10,0,0" Grid.ColumnSpan="3">
            <StatusBarItem Margin="0,0,0,3" Width="915">
                <TextBlock Text="{Binding StatusBarText}"/>
            </StatusBarItem>
        </StatusBar>

        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="Fix Traffic Pipeline"
                        DoubleClickCommand="{Binding ShowWindowCommand}"
                        Grid.ColumnSpan="3"
                        Grid.RowSpan="2"
                        Visibility="Collapsed">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Показать" Command="{Binding ShowWindowCommand}"/>
                    <MenuItem Header="Закрыть" Click="ExitMenuItem_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>