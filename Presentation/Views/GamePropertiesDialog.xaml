<Window x:Class="PlatformLauncher.Presentation.Views.GamePropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Свойства фикса" Height="200" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MainBackground}"
        Foreground="{DynamicResource MainForeground}">
    <Grid Margin="10" Background="{DynamicResource ControlBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding GameName}" FontWeight="Bold" Margin="0,0,0,10"
                   Foreground="{DynamicResource MainForeground}"/>
        <CheckBox x:Name="WarpCheckBox" Content="Запускать с WARP" Grid.Row="1" Margin="0,0,0,20"
                  IsChecked="{Binding WarpEnabled}"
                  Foreground="{DynamicResource MainForeground}"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,10,0" Click="OkButton_Click"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="{DynamicResource ControlForeground}"
                    BorderBrush="{DynamicResource BorderBrush}"/>
            <Button Content="Отмена" Width="80" Click="CancelButton_Click"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="{DynamicResource ControlForeground}"
                    BorderBrush="{DynamicResource BorderBrush}"/>
        </StackPanel>
    </Grid>
</Window>